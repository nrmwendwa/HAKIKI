# ============================================================================
# Hakiki Scanner API Configuration
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# API Configuration
# ============================================================================
# API host to bind to (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Enable debug mode (True/False)
DEBUG=False

# Number of worker processes for production (ignored in debug mode)
WORKERS=4

# ============================================================================
# Model Configuration
# ============================================================================
# Path to the model file (relative or absolute)
# The model should be a PyTorch .pth file
MODEL_PATH=models/efficientnet3class_full_model.pth

# Device to use for inference (cuda or cpu)
# Set to 'cpu' if CUDA is not available
DEVICE=cuda

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=10

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
# Include your frontend URL when deploying
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

